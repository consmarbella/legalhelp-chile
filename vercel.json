{
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate-final/route.ts": {
      "maxDuration": 60
    },
    "app/api/payment/create/route.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/nosotros", "destination": "/", "permanent": true },
    { "source": "/servicios", "destination": "/", "permanent": true },
    { "source": "/contacto", "destination": "/", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "http://legalhelp.cl" }], "destination": "https://legalhelp.cl/$1", "permanent": true }
  ]
}
